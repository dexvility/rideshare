# ── .env ─────────────────────────────────────────────────────────────────
# Copy this to .env and fill in values before running docker compose up -d

# PostgreSQL password — generate with: openssl rand -hex 24
POSTGRES_PASSWORD=change_me_strong_password

# Admin panel secret token — generate with: openssl rand -hex 32
# Access the admin panel at /admin
ADMIN_SECRET=change_me_admin_secret

# Local port the app is exposed on (only used by the default, proxy-less
# docker-compose.yml). The app will be reachable at http://localhost:<APP_PORT>
APP_PORT=3000

# Set to "true" to populate demo data on first boot (sample users and rides)
# Set to "false" (or omit) for a real deployment
DEMO_DATA=false

# ntfy.sh base URL — default is the public server, self-host if needed
# NTFY_URL=https://ntfy.sh

# Branding — only used to seed the theme on first boot. After that, change
# these from the Admin panel (/admin) instead; these env vars are ignored
# once a theme row already exists in the database.
APP_NAME=Ride Share
HERO_EMOJI=🚗
H1_TITLE=Ride Sharing
H2_SUBTITLE=Find or offer a ride

# ── Auth mode ─────────────────────────────────────────────────────────────
# "phone"    — phone-number lookup only (default, no password required)
# "password" — email + password with optional Google sign-in
AUTH_MODE=phone

# Public URL of the app — used in email links (no trailing slash)
APP_URL=https://example.com

# ── Google OAuth (only used when AUTH_MODE=password) ──────────────────────
# Create credentials at https://console.cloud.google.com/
# Authorised redirect URI must be: ${APP_URL}/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://example.com/api/auth/google/callback

# ── SMTP (required when AUTH_MODE=password) ────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false          # set to "true" for port 465
# SMTP_USER=user@example.com
# SMTP_PASS=
# SMTP_FROM="Ride Share <noreply@example.com>"
